# Meta-Human 本地环境配置
# 复制为 .env.local 后按本机实际路径填写。下列变量均与代码中实际读取的名称一一对应。
# 留空（或不配置）的引擎不会出现在前端可选项里，但「极速预览」始终可用（无需 Python）。

# ===== 公共依赖（Edge-TTS 语音 / ffmpeg 视频合成）=====

# Edge-TTS / 人脸检测共用的 Python 解释器（装了 edge-tts、mediapipe 等）。
# 极速预览与高质量模型都需要它来合成语音。
EDGE_TTS_PYTHON=D:/ai-code/sadtalker-venv/Scripts/python.exe

# ffmpeg / ffprobe 的 bin 目录（next.config 启动时注入 PATH）。
FFMPEG_BIN=C:/path/to/ffmpeg/bin

# ===== SadTalker 高质量口型引擎（「高质量模型」渲染引擎需要）=====

# SadTalker 仓库根目录（包含 inference.py 和 checkpoints/）
SADTALKER_DIR=D:/ai-code/SadTalker

# SadTalker 专用 Python 解释器（3.10 venv，已装 torch/basicsr/facexlib 等）
SADTALKER_PYTHON=D:/ai-code/sadtalker-venv/Scripts/python.exe

# 设备：默认 gpu（用 CUDA）；显式设 cpu 则用 --cpu
SADTALKER_DEVICE=gpu

# 可选：面部增强器，gfpgan / RestoreFormer / 留空关闭
# 有 CUDA GPU 时建议设为 gfpgan（仅 +3~5 秒）；纯 CPU 下 gfpgan 会让耗时成倍增加，建议留空。
SADTALKER_ENHANCER=gfpgan

# 可选：预处理模式 crop|extcrop|resize|full|extfull（默认 full，保留全身）
SADTALKER_PREPROCESS=full

# 可选：输出分辨率（如 512；留空使用 SadTalker 默认）
SADTALKER_SIZE=

# ===== MuseTalk 实时口型引擎（「实时口型」渲染引擎，支持照片/视频双输入）=====

# MuseTalk 仓库根目录（包含 scripts/inference.py 与 models/）
MUSETALK_DIR=D:/ai-code/MuseTalk

# MuseTalk 专用 Python 解释器
MUSETALK_PYTHON=D:/ai-code/musetalk-venv/Scripts/python.exe

# MuseTalk 用 os.system 调 ffmpeg 抽帧，需显式给 bin 目录（与 FFMPEG_BIN 同源，末尾带斜杠）
MUSETALK_FFMPEG_PATH=C:/path/to/ffmpeg/bin/

# GPU 编号（默认 0）
MUSETALK_GPU_ID=0

# 送入推理前长边缩放上限（默认 1280）。
# 手机原图常达 2000+ 像素，会显著拖慢推理并抬高显存；MuseTalk 实际只处理 256 脸部区域，
# 1280 已远超所需、不影响口型质量。显存吃紧可调小，追求细节可调大。
# MUSETALK_MAX_DIMENSION=1280
