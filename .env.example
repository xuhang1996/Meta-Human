# SadTalker 高质量口型模型配置（“高质量模型”渲染引擎需要）
# 复制为 .env.local 后按本机实际路径填写。缺省时高质量任务会失败并提示。

# SadTalker 仓库根目录（包含 inference.py 和 checkpoints/）
SADTALKER_DIR=/Users/yourname/SadTalker

# SadTalker 专用 Python 解释器（3.10 venv，已装 torch/basicsr/facexlib 等）
SADTALKER_PYTHON=/Users/yourname/sadtalker-venv/bin/python

# 可选：面部增强器，gfpgan / RestoreFormer / 留空关闭
# 默认留空：在 Apple Silicon CPU 上 gfpgan 会让 3 秒视频从 ~13 分钟涨到 40+ 分钟。
# 基础渲染已包含完整口型同步。有 CUDA GPU 时建议设为 gfpgan。
SADTALKER_ENHANCER=

# 可选：预处理模式 crop|extcrop|resize|full|extfull（默认 full，保留全身）
SADTALKER_PREPROCESS=full
